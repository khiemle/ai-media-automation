# ─────────────────────────────────────────────────────────
#  AI Media Automation — Core Pipeline Environment
#  Copy to pipeline.env and fill in your values
# ─────────────────────────────────────────────────────────
# DEPRECATED: This file will be removed. Use .env at project root instead.
# See .env.example for the current template.

# ── Database (same as console/.env) ───────────────────────
DATABASE_URL=postgresql://admin:123456@localhost:5432/ai_media
REDIS_URL=redis://localhost:6379/0

# ── LLM Configuration ─────────────────────────────────────
# Mode: local | gemini | auto | hybrid
#   local   = Qwen2.5 7B via Ollama only (free, offline)
#   gemini  = Gemini 2.5 Flash only (requires API key)
#   auto    = Gemini if quota available, else Ollama fallback
#   hybrid  = route by template (hook/cta → gemini, body → local)
LLM_MODE=auto

# Gemini API key for TEXT generation (script writing, RAG)
# Get free at https://aistudio.google.com/app/apikey
# Free tier: 1,500 req/day, 15 req/min
GEMINI_API_KEY=

# Gemini model to use for text (Flash = best quality/cost ratio)
GEMINI_MODEL=gemini-2.5-flash

# ── Media Generation (separate key + quota) ────────────────
# Gemini API key for MEDIA generation — Veo (video) + Imagen (photo/thumbnail)
# Use a DIFFERENT Google account/project to get separate free quota.
# Veo 2:    ~$0.35 per 8s clip (verify at https://ai.google.dev/pricing)
# Imagen 3: ~$0.04 per image   (verify at https://ai.google.dev/pricing)
GEMINI_MEDIA_API_KEY=

# Veo video generation model
# Testing:    veo-3.1-lite-generate-preview  ($0.05/sec → $0.40 per 8s clip)
# Production: veo-3.1-fast-generate-preview  ($0.10/sec → $0.80 per 8s clip)
# Max quality: veo-3.1-generate-preview      ($0.40/sec → $3.20 per 8s clip)
VEO_MODEL=veo-3.1-lite-generate-preview

# Imagen photo/thumbnail generation model
# Testing:    imagen-4.0-fast-generate-001   ($0.02/image)
# Production: imagen-4.0-generate-001        ($0.04/image)
# Max quality: imagen-4.0-ultra-generate-001 ($0.06/image)
IMAGEN_MODEL=imagen-4.0-fast-generate-001

# ── Scraper Credentials ────────────────────────────────────
# TikTok Research API — apply at https://developers.tiktok.com/
# Required for high-volume reliable scraping (primary source)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Apify — cloud scraping fallback — https://console.apify.com/account/integrations
# Free tier: $5 credit/month
APIFY_API_TOKEN=
APIFY_TIKTOK_ACTOR_ID=GdWCkxBtKWOsKjdch   # public TikTok Scraper actor

# Browser scraper runtime
# Engine: auto | playwright | selenium
TIKTOK_SCRAPER_ENGINE=auto
# true = headless; false = visible browser window
TIKTOK_BROWSER_HEADLESS=true
# Retry once with a visible browser if headless returns 0 items
TIKTOK_BROWSER_HEADFUL_RETRY_ON_EMPTY=true
# If Playwright still returns 0 items, retry with Selenium + Chromium
TIKTOK_SELENIUM_FALLBACK=true
TIKTOK_BROWSER_TIMEOUT_MS=30000
TIKTOK_BROWSER_SCROLL_COUNT=4
TIKTOK_BROWSER_SCROLL_DELAY_MS=1800
# Optional: chrome | msedge when using a locally installed browser channel
TIKTOK_BROWSER_CHANNEL=
# Optional: explicit Chrome/Chromium binary path for Playwright/Selenium
TIKTOK_CHROME_BINARY=

# ── Asset Sources ─────────────────────────────────────────
# Pexels API — free stock footage — https://www.pexels.com/api/
# Free tier: 200 req/hr, 20,000 req/month
PEXELS_API_KEY=

# ── Storage Paths ─────────────────────────────────────────
# Where Kokoro ONNX model + voices are stored
MODELS_PATH=./models

# Where video assets (pexels/, veo/, manual/) are stored
ASSET_DB_PATH=./assets/video_db

# Where finished videos go before upload
OUTPUT_PATH=./assets/output

# ── Pipeline Settings ─────────────────────────────────────
# Asset resolver mode: db_only | db_then_pexels | db_then_veo | db_then_hybrid
ASSET_RESOLVER_MODE=db_then_hybrid

# Minimum asset DB match score to use cached asset (0.0–1.0)
ASSET_DB_MIN_SCORE=0.72

# TTS voice and speed
TTS_VOICE=af_heart
TTS_SPEED=1.1

# Max Celery workers for rendering (GPU-bound — keep low)
RENDER_CONCURRENCY=2

# Target video resolution
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30

# ── Feedback Loop ─────────────────────────────────────────
# Minimum score (0–100) to reindex a script as high-quality
FEEDBACK_REINDEX_THRESHOLD=70

# Score below which a script is marked low-quality
FEEDBACK_LOW_QUALITY_THRESHOLD=40

# ── Notifications (optional) ──────────────────────────────
# Daily summary webhook (Slack, Discord, or n8n)
WEBHOOK_URL=
