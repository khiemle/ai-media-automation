# Stage 1 — build
FROM node:20-alpine AS builder
WORKDIR /app
COPY console/frontend/package*.json ./
RUN npm ci
COPY console/frontend/ ./
RUN npm run build

# Stage 2 — serve
FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
