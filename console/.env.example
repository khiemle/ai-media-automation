# ─────────────────────────────────────────────
#  AI Media Management Console — Environment
# ─────────────────────────────────────────────

# Database (shared with core pipeline)
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_media

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET=change-me-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Fernet encryption key for OAuth secrets
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required whenever credentials, uploads, or token refresh are enabled.
FERNET_KEY=

# Path to core pipeline root (for direct Python imports)
CORE_PIPELINE_PATH=..

# Console server
CONSOLE_PORT=8080
FRONTEND_ORIGIN=http://localhost:5173

# Environment
ENV=development

# Runway ML
RUNWAY_API_KEY=
