# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://admin:123456@localhost:5432/ai_media
REDIS_URL=redis://localhost:6379/0

# ── Console ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
FERNET_KEY=                # python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CORE_PIPELINE_PATH=..
CONSOLE_PORT=8080
FRONTEND_ORIGIN=http://localhost:5173
ENV=development

# ── LLM — Gemini ──────────────────────────────────────────────────────────────
LLM_MODE=gemini            # gemini | local | auto | hybrid
GEMINI_API_KEY=            # https://aistudio.google.com/app/apikey
GEMINI_MEDIA_API_KEY=      # for Veo generation (can be same as GEMINI_API_KEY)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_RPD=1500
GEMINI_RPM=15
VEO_MODEL=veo-3.1-lite-generate-preview

# ── LLM — Ollama (local fallback) ─────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# ── TTS ───────────────────────────────────────────────────────────────────────
TTS_ENGINE=auto            # auto | kokoro | elevenlabs
ELEVENLABS_API_KEY=        # https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_VOICE_ID_VI=    # Vietnamese voice ID from ElevenLabs dashboard
ELEVENLABS_VOICE_ID_EN=    # English voice ID (optional fallback)
MODELS_PATH=./models       # Path to Kokoro ONNX model directory

# ── Assets ────────────────────────────────────────────────────────────────────
PEXELS_API_KEY=            # https://www.pexels.com/api/
ASSET_RESOLVER_MODE=db_then_hybrid   # db_then_pexels | db_then_hybrid
ASSET_DB_MIN_SCORE=0.72
ASSET_DB_PATH=./assets/video_db
OUTPUT_PATH=./assets/output
MUSIC_PATH=./assets/music

# ── Pipeline Settings ─────────────────────────────────────────────────────────
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
FEEDBACK_REINDEX_THRESHOLD=70
FEEDBACK_LOW_QUALITY_THRESHOLD=40
